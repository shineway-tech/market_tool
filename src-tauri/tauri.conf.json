{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Channel Nest",
  "version": "1.0.3",
  "identifier": "com.marketingmaster.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Channel Nest",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxMTJBQkRCM0Y5MTA4OTQKUldTVUNKRS8yNnNTd1hrTkc5a2R5OXlHRHBjVjRWeHJUMmUxWmhlbW1BcHNTREY4T0xxeHNjNlEK",
      "endpoints": [
        "https://market-api.honeykid.cn/v1/desktop-updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dangerousInsecureTransportProtocol": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
